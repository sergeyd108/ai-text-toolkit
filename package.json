{
  "name": "ai-text-toolkit",
  "private": true,
  "type": "module",
  "imports": {
    "#main.css": "./app/assets/css/main.css"
  },
  "scripts": {
    "dev": "nuxt dev --host",
    "typecheck": "nuxt typecheck",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --write .",
    "pkg:up:minor": "pnpm dlx taze minor -l -w && pnpm i",
    "pkg:up:major": "pnpm dlx taze major -l -w && pnpm i"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.52",
    "@ai-sdk/vue": "3.0.158",
    "@iconify-json/lucide": "1.2.102",
    "@iconify-json/simple-icons": "1.2.77",
    "@nuxt/ui": "4.6.1",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/typography": "0.5.19",
    "@tiptap/core": "3.22.3",
    "@tiptap/pm": "3.22.3",
    "@tiptap/vue-3": "3.22.3",
    "@vueuse/nuxt": "14.2.1",
    "ai": "6.0.158",
    "diff": "8.0.4",
    "diff2html": "3.4.56",
    "dompurify": "3.3.3",
    "marked": "18.0.0",
    "nuxt": "4.4.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.2",
    "@pinia/testing": "1.0.3",
    "@tailwindcss/postcss": "4.2.2",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.2.0",
    "happy-dom": "20.8.9",
    "pinia": "3.0.4",
    "prettier": "3.8.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "sass-embedded": "1.99.0",
    "tailwindcss": "4.2.2",
    "taze": "19.11.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "vue-tsc": "3.2.6"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "patchedDependencies": {
      "@nuxt/ui@4.6.1": "patches/@nuxt__ui.patch"
    }
  }
}
